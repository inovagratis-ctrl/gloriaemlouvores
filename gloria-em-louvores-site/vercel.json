{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/api/videos/:id", "destination": "/api/index.ts?resource=videos&id=:id" },
    { "source": "/api/videos", "destination": "/api/index.ts?resource=videos" },
    { "source": "/api/blog/:id", "destination": "/api/index.ts?resource=blog&id=:id" },
    { "source": "/api/blog", "destination": "/api/index.ts?resource=blog" },
    { "source": "/api/psalms/:id", "destination": "/api/index.ts?resource=psalms&id=:id" },
    { "source": "/api/psalms", "destination": "/api/index.ts?resource=psalms" },
    { "source": "/api/shorts/:id", "destination": "/api/index.ts?resource=shorts&id=:id" },
    { "source": "/api/shorts", "destination": "/api/index.ts?resource=shorts" },
    { "source": "/api/requests/:id", "destination": "/api/index.ts?resource=requests&id=:id" },
    { "source": "/api/requests", "destination": "/api/index.ts?resource=requests" },
    { "source": "/api/channel-stats", "destination": "/api/index.ts?resource=channel-stats" },
    { "source": "/api/admin-auth", "destination": "/api/index.ts?resource=admin-auth" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml" }]
    },
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain" }]
    }
  ]
}